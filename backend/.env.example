PORT=3000
# Base publica usada para construir enlaces. Si no se define, el backend usa el origen de la request.
PUBLIC_API_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:5173
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=YOUR_ACCOUNT;AccountKey=YOUR_KEY;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER=documents
MAX_FILE_SIZE_MB=25
JSON_BODY_LIMIT=50mb
AUTH_ENV_URL=https://ffihaeatoundrjzgtpzk.supabase.co/functions/v1/get-env
AUTH_ENV_ACCESS_KEY=YOUR_AUTH_ENV_ACCESS_KEY
AUTH_CONFIG_CACHE_MS=60000
